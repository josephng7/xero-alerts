# Copy to `.env.local` and fill in values. Skip sections you do not use.
#
# Omitted on purpose (not listed below): `NODE_ENV` — set by Next.js / tooling; `VERCEL_URL` — injected on Vercel.
# Public origin when unset is inferred: optional NEXTAUTH_URL → VERCEL_URL → http://localhost:3000 (`lib/server/app-base-url.ts`).
# Omit `QSTASH_URL` to use default Upstash API origin https://qstash.upstash.io when `QSTASH_TOKEN` is set.

# App and session (NextAuth / canonical URL)
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# Xero
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Optional. Space-separated OAuth2 scopes. Default: openid profile email accounting.contacts.read offline_access
# (must match scopes enabled for this app in the Xero Developer portal; see docs/runbooks/go-live.md)
XERO_OAUTH_SCOPES=
XERO_WEBHOOK_KEY=
XERO_ALLOWED_TENANT_ID=

# Security
TOKEN_ENCRYPTION_KEY=
# Cron-only internal routes (e.g. scheduled poll). Optional previous value during rotation.
INTERNAL_CRON_SECRET=
INTERNAL_CRON_SECRET_PREVIOUS=
# Admin and job internal routes (sync, process-event, notify). Optional previous during rotation.
INTERNAL_ADMIN_SECRET=
INTERNAL_ADMIN_SECRET_PREVIOUS=

# Data Stores
# Supabase Postgres (required for dev and prod). No local Docker DB — use your Supabase project.
# Dashboard: Project Settings → Database → Connection string (URI).
# Prefer the "Transaction pooler" URI for serverless / Next.js (port 6543); use "Direct" if your host requires it.
DATABASE_URL=

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Queue and Scheduling
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Notifications
TEAMS_WEBHOOK_URL=
RESEND_API_KEY=
ALERTS_FROM_EMAIL=
ALERTS_TO_EMAIL=

# Observability
SENTRY_DSN=
