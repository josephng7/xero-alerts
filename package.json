{
  "name": "xero-alerts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "echo \"No integration tests yet\"",
    "check:pm": "node scripts/check-package-manager.cjs",
    "check:agents": "node scripts/check-agents-compliance.cjs",
    "verify": "pnpm run check:pm && pnpm run check:agents && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
